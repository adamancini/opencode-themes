    "markdownImage": {
      "dark": "cyan",
      "light": "cyan"
    },
    "markdownImageText": {
      "dark": "magenta",
      "light": "magenta"
    },
    "markdownCodeBlock": {
      "dark": "fg",
      "light": "bg"
    },
