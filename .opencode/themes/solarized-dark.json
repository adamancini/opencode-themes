      "light": "fg"
    },
    "backgroundPanel": {
      "dark": "black",
      "light": "white"
    },
    "backgroundElement": {
      "dark": "black",
      "light": "white"
    },
    "border": {
      "dark": "brightBlack",
      "light": "brightBlack"
    },
    "borderActive": {
      "dark": "white",
      "light": "black"
    },
    "borderSubtle": {
      "dark": "black",
      "light": "white"
