      "dark": "blue",
      "light": "blue"
    },
    "syntaxFunction": {
      "dark": "cyan",
      "light": "cyan"
    },
    "syntaxVariable": {
      "dark": "red",
      "light": "red"
    },
    "syntaxString": {
      "dark": "green",
      "light": "green"
    },
    "syntaxNumber": {
      "dark": "magenta",
      "light": "magenta"
    },
    "syntaxType": {
      "dark": "yellow",
      "light": "yellow"
    },
    "syntaxOperator": {
      "dark": "cyan",
      "light": "cyan"
    },
    "syntaxPunctuation": {
      "dark": "fg",
      "light": "bg"
    }
