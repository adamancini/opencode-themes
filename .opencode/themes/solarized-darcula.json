{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "black": "#25292a",
    "red": "#f24840",
    "green": "#629655",
    "yellow": "#b68800",
    "blue": "#2075c7",
    "magenta": "#797fd4",
    "cyan": "#15968d",
    "white": "#d2d8d9",
    "brightBlack": "#25292a",
    "brightRed": "#f24840",
    "brightGreen": "#629655",
    "brightYellow": "#b68800",
    "brightBlue": "#2075c7",
    "brightMagenta": "#797fd4",
    "brightCyan": "#15968d",
    "brightWhite": "#d2d8d9",
    "bg": "#3d3f41",
    "fg": "#d2d8d9"
  },
  "theme": {
    "primary": {
      "dark": "blue",
      "light": "blue"
    },
    "secondary": {
      "dark": "cyan",
      "light": "cyan"
    },
    "accent": {
      "dark": "magenta",
      "light": "magenta"
    },
    "error": {
      "dark": "red",
      "light": "red"
    },
    "warning": {
      "dark": "yellow",
      "light": "yellow"
