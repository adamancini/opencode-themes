      "dark": "text",
      "light": "text"
    },
    "markdownHeading": {
      "dark": "primary",
      "light": "primary"
    },
    "markdownLink": {
      "dark": "cyan",
      "light": "cyan"
    },
    "markdownLinkText": {
      "dark": "blue",
      "light": "blue"
