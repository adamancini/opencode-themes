    "bgPanel": "#F3F3F3",
    "bgElement": "#e3e3e3",
    "fg": "#236ebf",
    "text": "#1857a4",
    "muted": "#5f7e97",
    "border": "#ccc",
    "borderActive": "#219fd5",
    "borderSubtle": "#e3e3e3",
