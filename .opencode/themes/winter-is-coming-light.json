      "dark": "comment",
      "light": "comment"
    },
    "syntaxKeyword": {
      "dark": "cyan",
      "light": "cyan"
    },
    "syntaxFunction": {
      "dark": "blue",
      "light": "blue"
    },
    "syntaxVariable": {
      "dark": "text",
      "light": "text"
    },
    "syntaxString": {
      "dark": "green",
      "light": "green"
    },
    "syntaxNumber": {
      "dark": "mint",
      "light": "mint"
    },
    "syntaxType": {
      "dark": "purple",
      "light": "purple"
    },
    "syntaxOperator": {
      "dark": "cyan",
      "light": "cyan"
    },
    "syntaxPunctuation": {
      "dark": "darkText",
      "light": "darkText"
