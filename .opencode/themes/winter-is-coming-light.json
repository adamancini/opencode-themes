    "backgroundPanel": {
      "dark": "bgPanel",
      "light": "bgPanel"
    },
    "backgroundElement": {
      "dark": "bgElement",
      "light": "bgElement"
    },
    "border": {
      "dark": "border",
      "light": "border"
